# Copy to .env.local and fill in when ready.

# Make.com / n8n / Zapier webhook for form submissions
SUBMIT_WEBHOOK_URL=

# Stripe (future)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Claude API for the AI Concierge (future)
ANTHROPIC_API_KEY=

# Database (used by /itinerary when set; falls back to local storage otherwise)
MONGODB_URI=
MONGODB_DB=worldcup_itinerary
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google OAuth + Gmail send (for /itinerary)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SENDER_EMAIL=
ADMIN_EMAIL=

# Email capture (future)
MAILCHIMP_API_KEY=
CONVERTKIT_API_KEY=

# Google Maps (future)
GOOGLE_MAPS_API_KEY=
